NODE_ENV=production
HOST=0.0.0.0
PORT=5173
PUBLIC_BASE_URL=http://127.0.0.1:5173

# ── 必填：凭据加密 master key ────────────────────────────────────
# AES-256-GCM 用此 key 加密用户保存的 SSH 密码 / 私钥。
# **丢失 = 所有保存的凭据永久无法解开**——离线备份这个值（密码管理器 / 物理保险箱）。
# **部署后切勿更换**——会让所有用户的连接失效。
#
# 生成方法（任选）：
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   openssl rand -base64 32
ENVFORGE_MASTER_KEY=

# ── 数据持久化 ───────────────────────────────────────────────────
# 容器中默认 /app/data；本地开发默认 ./data。
FOOL_DATA_DIR=data
FOOL_RUNTIME_DB=data/runtime-db.json
FOOL_SNAPSHOT_DIR=data/snapshots

# ── Web UI 服务 ──────────────────────────────────────────────────
# 生产环境 API 同时托管 apps/web/dist 静态文件（同一进程，少一个反代环节）。
SERVE_WEB=1
WEB_DIST_DIR=apps/web/dist

# ── Session ──────────────────────────────────────────────────────
# 本地账号 session 有效期。168 小时 = 7 天。
SESSION_TTL_HOURS=168

# ── Authorization ────────────────────────────────────────────────
# 逗号分隔的邮箱列表，注册 / 登录时自动获得 admin 角色。
# 至少填一个 —— 否则没人能管 catalog。
# ENVFORGE_ADMIN_EMAILS=admin@example.com,ops@example.com

# ── GitHub OAuth (可选) ──────────────────────────────────────────
# 在 https://github.com/settings/developers 创建 OAuth App。
# Authorization callback URL **必须**与 GITHUB_REDIRECT_URI 完全一致（包括 https / 路径）。
# 未配置时登录页不会显示 GitHub 按钮，OAuth 路由返回 503。
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=https://envforge.example.com/auth/github/callback

# ── Google OAuth (可选) ──────────────────────────────────────────
# 在 Google Cloud Console 创建 OAuth 2.0 凭据。
# Redirect URI 必须为 /auth/google/callback 路径。
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://envforge.example.com/auth/google/callback

# ── SMTP for email verification (可选) ───────────────────────────
# 不配时验证码会输出到容器 stdout（仅开发环境用——公网部署务必配）。
# Gmail 推荐：用应用专用密码，不要主密码（参见 docs/AUTH.md）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASS=app-specific-password
# SMTP_FROM=EnvForge <your-gmail@gmail.com>

# 每用户每小时邮件发送上限（防滥用 / 防 SMTP rate limit 触发）
# EMAIL_RATE_PER_USER_PER_HOUR=30
