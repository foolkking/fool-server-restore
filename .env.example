NODE_ENV=production
HOST=0.0.0.0
PORT=5173
PUBLIC_BASE_URL=http://127.0.0.1:5173

# Runtime data is intentionally outside tracked source files.
FOOL_DATA_DIR=data
FOOL_RUNTIME_DB=data/runtime-db.json
FOOL_SNAPSHOT_DIR=data/snapshots

# In production, the API can serve apps/web/dist from the same process.
SERVE_WEB=1
WEB_DIST_DIR=apps/web/dist

# Local account sessions. 168 hours = 7 days.
SESSION_TTL_HOURS=168

# ── Authorization ────────────────────────────────────────────────
# Comma-separated list of emails that automatically receive admin role on register/login.
# ENVFORGE_ADMIN_EMAILS=admin@example.com,ops@example.com

# ── GitHub OAuth (optional) ──────────────────────────────────────
# Register an OAuth App at https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://127.0.0.1:5173/api/auth/github/callback

# ── SMTP for email verification (optional) ───────────────────────
# When unset, registration verification codes are logged to stdout (dev only).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=EnvForge <noreply@example.com>
